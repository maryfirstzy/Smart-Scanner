# --- Parsing Engine Execution Core ---
def evaluate_signature_metrics(sig_hex, z_hex=None):
    """Analyzes raw cryptographic components to update the metrics dashboard."""
    components = parse_der_signature(sig_hex)
    if not components:
        return
    
    r_val, s_val = components
    
    # Process S-Value Constraints (BIP62 Rule Enforcement Checking)
    if s_val <= HALF_SECP256K1_ORDER:
        metrics['vulnerability_counts']['Low S Signature'] += 1
    else:
        metrics['vulnerability_counts']['High S Signature'] += 1
        
    # Process Message-Hash Z tracking if present
    if z_hex:
        metrics['vulnerability_counts']['Signature Z'] += 1

