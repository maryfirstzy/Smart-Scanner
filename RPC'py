# --- Automated Testing Suite & Cryptographic Generator ---
class TestInputGenerator:
    """
    Generates cryptographically valid inputs, private keys, and customized signatures
    to verify scanner functionality locally without an external network.
    """
    @staticmethod
    def generate_random_private_key():
        """Generates a secure, random SECP256k1 private key hex string."""
        sk = SigningKey.generate(curve=SECP256k1)
        return binascii.hexlify(sk.to_string()).decode('utf-8')

    @staticmethod
    def create_custom_signature_der(private_key_hex, message_string, force_high_s=False):
        """
        Signs a mock message and extracts the resulting components.
        Allows forcing high or low S components for parser validation.
        """
        private_bytes = binascii.unhexlify(private_key_hex)
        sk = SigningKey.from_string(private_bytes, curve=SECP256k1)
        
        # Calculate the Message Hash (Z Value)
        z_hash = hashlib.sha256(message_string.encode('utf-8')).digest()
        
        # Generate raw ECDSA signature elements
        sig_raw = sk.sign_digest(z_hash, sigencode=lambda r, s, order: (r, s))
        r_val = int.from_bytes(sig_raw[:32], 'big')
        s_val = int.from_bytes(sig_raw[32:], 'big')

        # Manipulate S signature properties to simulate canonical vs high-S behaviors
        if force_high_s and s_val <= HALF_SECP256K1_ORDER:
            s_val = SECP256K1_ORDER - s_val
        elif not force_high_s and s_val > HALF_SECP256K1_ORDER:
            s_val = SECP256K1_ORDER - s_val

        # Encode components into a standard DER byte structure
        r_bytes = r_val.to_bytes((r_val.bit_length() + 7) // 8, 'big')
        s_bytes = s_val.to_bytes((s_val.bit_length() + 7) // 8, 'big')
        
        # Pad values properly for DER notation if the leading bit is set
        if r_bytes[0] & 0x80: r_bytes = b'\x00' + r_bytes
        if s_bytes[0] & 0x80: s_bytes = b'\x00' + s_bytes

        der_built = bytearray([0x30, len(r_bytes) + len(s_bytes) + 4, 0x02, len(r_bytes)]) + r_bytes + bytearray([0x02, len(s_bytes)]) + s_bytes
        return binascii.hexlify(der_built).decode('utf-8'), binascii.hexlify(z_hash).decode('utf-8')

# --- Local Bitcoin Core RPC Client Connection ---
def bitcoin_rpc_call(method, params=[]):
    """Executes atomic JSON-RPC requests to a running Bitcoin Core daemon."""
    payload = {
        "jsonrpc": "1.0",
        "id": "sig_scanner",
        "method": method,
        "params": params
    }
    try:
        response = requests.post(
            RPC_CONFIG["url"],
            auth=(RPC_CONFIG["user"], RPC_CONFIG["password"]),
            json=payload,
            timeout=5
        )
        if response.status_code == 200:
            return response.json().get("result", None)
    except Exception:
        return None
    return None

# --- Cryptographic Helper Methods ---
def parse_der_signature(sig_hex):
    try:
        sig_bytes = binascii.unhexlify(sig_hex)
        if len(sig_bytes) < 8 or sig_bytes[0] != 0x30:
            return None
        r_length = sig_bytes[1]
        r_start = 4
        if r_start + r_length >= len(sig_bytes): return None
        r_bytes = sig_bytes[r_start:r_start + r_length]
        s_len_idx = r_start + r_length
        if s_len_idx + 1 >= len(sig_bytes): return None
        s_length = sig_bytes[s_len_idx + 1]
        s_start = s_len_idx + 2
        if s_start + s_length > len(sig_bytes): return None
        s_bytes = sig_bytes[s_start:s_start + s_length]
        return int.from_bytes(r_bytes, 'big'), int.from_bytes(s_bytes, 'big')
    except Exception:
        return None

